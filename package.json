{
  "name": "edith-m2",
  "private": true,
  "version": "2.0.0",
  "description": "E.D.I.T.H. M2 desktop app",
  "author": "Edith",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepare:backend": "bash scripts/prepare_backend_resources.sh",
    "launch": "bash launch_m2_desktop.sh",
    "electron": "npm run electron:dev",
    "electron:dev": "concurrently --kill-others-on-fail \"vite --port ${EDITH_M2_FRONTEND_PORT:-5176} --strictPort\" \"wait-on http://localhost:${EDITH_M2_FRONTEND_PORT:-5176} && electron .\"",
    "dist": "npm run build && npm run prepare:backend && electron-builder"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.2",
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.edith.m2",
    "productName": "E.D.I.T.H. M2",
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "target": "dir"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/extraResources/edith_backend",
        "to": "edith_backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
